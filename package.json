{
  "name": "akinator-api-v2-unofficial",
  "version": "1.0.0",
  "description": "Módulo JS não-official para a API do Akinator",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build": "npm run build:esm && npm run build:cjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "akinator",
    "api",
    "unofficial",
    "game",
    "guess"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "got-scraping": "^4.2.1"
  }
}
