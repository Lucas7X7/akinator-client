{
  "name": "akinator-client",
  "version": "1.2.0",
  "description": "Unofficial Node.js/TypeScript client for the Akinator game API",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build": "npm run build:esm && npm run build:cjs",
    "test": "vitest run src/test.test.ts",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Lucas7X7/akinator-client.git"
  },
  "bugs": {
    "url": "https://github.com/Lucas7X7/akinator-client/issues"
  },
  "homepage": "https://github.com/Lucas7X7/akinator-client#readme",
  "keywords": [
    "akinator",
    "api",
    "unofficial",
    "game",
    "guess",
    "typescript",
    "nodejs"
  ],
  "author": "Lucas7X7",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.5.0",
    "vitest": "^3.2.7"
  },
  "dependencies": {
    "got-scraping": "^4.2.1"
  }
}
